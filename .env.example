# NEXUS CRM v2 - CONFIGURAÇÃO EXAMPLO SUPABASE CLOUD (PaaS)

# Banco de Dados Supabase (Nuvem)
DATABASE_URL=postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Configurações do Aplicativo
NODE_ENV=production
PORT=3000
JWT_SECRET=sua_chave_secreta_jwt_longa_e_segura

# APIs de IA
VITE_GEMINI_API_KEY=sua_chave_do_gemini

# Supabase Client (Frontend)
VITE_SUPABASE_URL=URL_DO_SUPABASE
VITE_SUPABASE_ANON_KEY=ANON_KEY_DO_SUPABASE

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
