# NEXUS CRM v2 - CONFIGURAÇÃO EXAMPLO SUPABASE CLOUD (PaaS)

# Banco de Dados Supabase Cloud (Nuvem)
# Obter em: https://supabase.com/dashboard → Settings → Database → Connection String
# IMPORTANTE: Usar porta 6543 (Transaction Pooler) com SSL
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Configurações do Aplicativo
NODE_ENV=production
PORT=3000
JWT_SECRET=sua_chave_secreta_jwt_longa_e_segura
ALLOW_SIMULATED_MODE=false

# APIs de IA
VITE_GEMINI_API_KEY=sua_chave_do_gemini

# 🗄️ Supabase Cloud - Project: mxopomydvkyfdtlooypd
# Obter senha em: https://supabase.com/dashboard/project/mxopomydvkyfdtlooypd/settings/database
# Usar Transaction Pooler (porta 6543) com SSL
DATABASE_URL=postgresql://postgres.mxopomydvkyfdtlooypd:[SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
VITE_SUPABASE_URL=https://mxopomydvkyfdtlooypd.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
